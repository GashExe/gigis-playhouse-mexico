// Plataforma Gigi's Playhouse México
// Esquema de datos: usuarios (roles), estudiantes, programas, inscripciones y evaluaciones.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Cuentas del sistema: la directora administra todo; las maestras consultan y registran.
model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique // Identificador de acceso (usuario). Para alumnos: su matrícula.
  email        String?  @unique // Opcional: dato de contacto, ya no se usa para entrar
  passwordHash String
  role         Role     @default(MAESTRA)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Contraseña inicial autogenerada (texto). Visible SOLO para la directora, para
  // poder entregársela/reimprimirla a la familia. No se expone al cliente en general.
  initialPassword String?

  // Cuenta ligada a un participante (solo para role ALUMNO).
  studentId String?  @unique
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  evaluations Evaluation[] @relation("EvaluadorEvaluaciones")
  programs    Program[]    @relation("MaestroPrograma") // Programas/actividades a su cargo

  @@index([role])
}

enum Role {
  DIRECTORA
  MAESTRA
  ALUMNO
}

/// Estudiantes ("participantes") de Gigi's Playhouse.
model Student {
  id            String        @id @default(cuid())
  matricula     String?       @unique // Matrícula Gigi's (solo dígitos). Es el usuario de acceso.
  firstName     String
  lastName      String
  birthDate     DateTime?
  gender        Gender?
  photoUrl      String?
  // Tutor / familiar responsable
  guardianName  String?
  guardianPhone String?
  guardianEmail String?
  address       String?
  // Notas generales (intereses, apoyos, observaciones). Datos sensibles: acceso solo autenticado.
  notes         String?
  enrollmentDate DateTime     @default(now())
  status        StudentStatus @default(ACTIVO)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  enrollments Enrollment[]
  evaluations Evaluation[]
  account     User? // Cuenta de acceso del participante (role ALUMNO)

  @@index([status])
  @@index([lastName])
}

enum Gender {
  FEMENINO
  MASCULINO
  OTRO
}

enum StudentStatus {
  ACTIVO
  INACTIVO
  EGRESADO
}

/// Programa / actividad que se ofrece a los participantes.
/// Cada programa es una actividad con horario, cupo y un maestro a cargo.
model Program {
  id          String   @id @default(cuid())
  name        String
  description String?
  area        String?  // Área o categoría del programa
  color       String?  // Color para identificarlo visualmente
  active      Boolean  @default(true)

  // Datos de la actividad (todos editables)
  schedule             String? // Horario (ej. "Lunes y miércoles 10:00–11:00")
  type                 String? // Tipo de actividad
  ageMin               Int? // Rango de edad: edad mínima (años)
  ageMax               Int? // Rango de edad: edad máxima (años)
  studentCapacity      Int     @default(7) // Cupo de alumnos
  collaboratorCapacity Int? // Cupo de colaboradores

  // Maestro a cargo del programa/actividad
  teacher   User?   @relation("MaestroPrograma", fields: [teacherId], references: [id], onDelete: SetNull)
  teacherId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments Enrollment[]
  evaluations Evaluation[]

  @@index([active])
  @@index([teacherId])
}

/// Inscripción de un estudiante a un programa (relación con historial).
/// La calificación es POR PROGRAMA: un nivel que el maestro registra/actualiza
/// para el alumno en ese programa (no es un examen con título/puntaje).
model Enrollment {
  id        String           @id @default(cuid())
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  program   Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId String
  startDate DateTime         @default(now())
  endDate   DateTime?
  status    EnrollmentStatus @default(ACTIVA)
  notes     String?

  // Calificación por programa
  level     String? // Nivel: "Inicial", "En proceso", "Logrado"
  levelNote String? // Nota breve del maestro sobre el nivel
  gradedAt  DateTime? // Última vez que se registró la calificación

  createdAt DateTime @default(now())

  @@unique([studentId, programId])
  @@index([programId])
}

enum EnrollmentStatus {
  ACTIVA
  PAUSADA
  FINALIZADA
}

/// Evaluación / calificación de un estudiante en un momento dado.
model Evaluation {
  id          String   @id @default(cuid())
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId   String
  program     Program? @relation(fields: [programId], references: [id], onDelete: SetNull)
  programId   String?
  date        DateTime @default(now())
  title       String
  score       Float?   // Calificación numérica (opcional)
  scale       String?  // Escala o rúbrica usada (ej. "1-10", "Logrado / En proceso")
  level       String?  // Nivel cualitativo (ej. "Logrado", "En proceso", "Inicial")
  notes       String?
  evaluator   User?    @relation("EvaluadorEvaluaciones", fields: [evaluatorId], references: [id], onDelete: SetNull)
  evaluatorId String?
  createdAt   DateTime @default(now())

  @@index([studentId])
  @@index([date])
}
