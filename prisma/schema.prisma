// Plataforma Gigi's Playhouse México
// Esquema de datos: usuarios (roles), estudiantes, programas, inscripciones y evaluaciones.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Cuentas del sistema: la directora administra todo; las maestras consultan y registran.
model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique // Identificador de acceso (usuario). Para alumnos: su matrícula.
  email        String?  @unique // Opcional: dato de contacto, ya no se usa para entrar
  passwordHash String
  role         Role     @default(MAESTRA)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Contraseña inicial autogenerada (texto). Visible SOLO para la directora, para
  // poder entregársela/reimprimirla a la familia. No se expone al cliente en general.
  initialPassword String?

  // Cuenta ligada a un participante (solo para role ALUMNO).
  studentId String?  @unique
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  evaluations Evaluation[] @relation("EvaluadorEvaluaciones")
  programs    Program[]    @relation("MaestroPrograma") // Programas/actividades a su cargo
  studentNotes StudentNote[] @relation("AutorAnotaciones") // Anotaciones que ha escrito

  @@index([role])
}

enum Role {
  DIRECTORA
  COORDINADOR // Coordinador de programas educativos: arma y edita las plantillas de evaluación
  MAESTRA
  ALUMNO
}

/// Estudiantes ("participantes") de Gigi's Playhouse.
model Student {
  id            String        @id @default(cuid())
  matricula     String?       @unique // Matrícula Gigi's (solo dígitos). Es el usuario de acceso.
  firstName     String
  lastName      String
  birthDate     DateTime?
  gender        Gender?
  photoUrl      String?
  // Tutor / familiar responsable
  guardianName  String?
  guardianPhone String?
  guardianEmail String?
  address       String?
  // Notas generales (intereses, apoyos, observaciones). Datos sensibles: acceso solo autenticado.
  notes         String?
  enrollmentDate DateTime     @default(now())
  status        StudentStatus @default(ACTIVO)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Onboarding del tutor (primer ingreso). La compuerta a "clases" exige que estén
  // los tres: datos básicos + cuestionario de salud + aceptación de aviso y reglamento.
  onboardingCompletedAt DateTime? // Se marca al terminar el formulario de bienvenida
  privacyAcceptedAt     DateTime? // Cuándo aceptó el aviso de privacidad
  rulesAcceptedAt       DateTime? // Cuándo aceptó el reglamento
  consentVersion        String? // Versión de aviso/reglamento aceptada (para re-pedir si cambia)

  enrollments  Enrollment[]
  evaluations  Evaluation[]
  levelRecords LevelRecord[] // Ubicación de nivel por programa y ciclo
  itemScores   ItemScore[] // Calificaciones por tema de la plantilla (1–4) por ciclo
  health       HealthProfile? // Cuestionario de salud del participante
  account      User? // Cuenta de acceso del participante (role ALUMNO)
  attendance   AttendanceRecord[] // Asistencia por clase
  studentNotes StudentNote[] // Anotaciones del equipo sobre el participante

  @@index([status])
  @@index([lastName])
}

/// Cuestionario de salud del participante (1:1 con Student). Datos sensibles:
/// acceso solo autenticado. Lo llena el tutor en su primer ingreso.
model HealthProfile {
  id        String  @id @default(cuid())
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String  @unique

  bloodType           String? // Tipo de sangre
  allergies           String? // Alergias (o "Ninguna")
  medications         String? // Medicamentos actuales
  medicalConditions   String? // Condiciones médicas / diagnóstico
  therapies           String? // Terapias externas
  dietaryRestrictions String? // Restricciones alimentarias
  doctorName          String? // Médico de cabecera
  doctorPhone         String? // Teléfono del médico
  emergencyName       String? // Contacto de emergencia: nombre
  emergencyPhone      String? // Contacto de emergencia: teléfono
  emergencyRelation   String? // Parentesco del contacto de emergencia
  notes               String? // Observaciones de salud

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Gender {
  FEMENINO
  MASCULINO
  OTRO
}

enum StudentStatus {
  ACTIVO
  INACTIVO
  EGRESADO
}

/// Programa / actividad que se ofrece a los participantes.
/// Cada programa es una actividad con horario, cupo y un maestro a cargo.
model Program {
  id          String   @id @default(cuid())
  name        String
  description String?
  area        String?  // Área o categoría del programa
  color       String?  // Color para identificarlo visualmente
  active      Boolean  @default(true)

  // Plantilla de evaluación: qué forma tiene y con qué % se pasa de nivel.
  evalFormat    EvalFormat @default(BLOQUES) // BLOQUES (Mate/Lecto), AREAS (Lenguaje), PLANO (Danza/T.O./T.Física)
  passThreshold Int        @default(80) // % del nivel para pasar al siguiente

  // Datos de la actividad (todos editables)
  schedule             String? // Horario (ej. "Lunes y miércoles 10:00–11:00")
  type                 String? // Tipo de actividad
  ageMin               Int? // Rango de edad: edad mínima (años)
  ageMax               Int? // Rango de edad: edad máxima (años)
  studentCapacity      Int     @default(7) // Cupo de alumnos
  collaboratorCapacity Int? // Cupo de colaboradores

  // Maestro a cargo del programa/actividad
  teacher   User?   @relation("MaestroPrograma", fields: [teacherId], references: [id], onDelete: SetNull)
  teacherId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments  Enrollment[]
  evaluations  Evaluation[]
  levels       ProgramLevel[] // Niveles propios de este programa (ordenados)
  levelRecords LevelRecord[]
  scheduleSlots ScheduleSlot[] // Horario estructurado (día + horas); alimenta el calendario
  classSessions ClassSession[] // Bitácora y asistencia por fecha de clase
  studentNotes  StudentNote[] // Anotaciones ligadas a este programa
  // En qué ciclos se ofrece. La directora arma la oferta de cada ciclo eligiendo de
  // los programas que ya existen (ej. que en Sep–Dic solo corran 7). El programa
  // sigue siendo uno solo: conserva su plantilla, sus niveles y su historial.
  cycles       Cycle[]        @relation("ProgramasDelCiclo")

  @@index([active])
  @@index([teacherId])
}

/// Nivel propio de un programa. Cada programa define su propia lista ordenada
/// (ej. Lectura: Prerrequisitos, Inicial, Intermedio, Avanzado). Es la base sobre
/// la que colgarán, más adelante, los BLOQUES desbloqueables por nivel.
model ProgramLevel {
  id          String  @id @default(cuid())
  program     Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId   String
  name        String // Nombre del nivel (ej. "Nivel intermedio")
  order       Int // Posición dentro del programa (1 = primero)
  description String? // Qué abarca el nivel (ej. "ser un lector")

  records LevelRecord[]
  blocks  EvalBlock[] // Bloques/áreas de la plantilla que cuelgan de este nivel

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([programId, order])
  @@index([programId])
}

/// Ciclo escolar por temporada. Los cursos corren en tres ciclos al año:
/// Ene–Jun (largo), Jul–Ago (verano, corto) y Sep–Dic (largo).
model Cycle {
  id     String      @id @default(cuid())
  season CycleSeason // Temporada del ciclo
  year   Int // Año calendario
  label  String // Etiqueta legible (ej. "Ene–Jun 2026")
  active Boolean     @default(false) // Ciclo vigente para registrar

  records     LevelRecord[]
  itemScores  ItemScore[] // Calificaciones por tema registradas en este ciclo
  enrollments Enrollment[] // Inscripciones de este ciclo
  programs    Program[]    @relation("ProgramasDelCiclo") // Qué programas se ofrecen en este ciclo

  createdAt DateTime @default(now())

  @@unique([season, year])
  @@index([active])
}

enum CycleSeason {
  ENE_JUN
  JUL_AGO
  SEP_DIC
}

/// Ubicación de un alumno en un nivel de un programa, en un ciclo concreto.
/// Es la "calificación por programa" con historial por ciclo (el xlsx de titulares
/// por niveles es exactamente esto para Lectura/Escritura/Matemáticas).
model LevelRecord {
  id             String          @id @default(cuid())
  student        Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId      String
  program        Program         @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId      String
  cycle          Cycle           @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  cycleId        String
  level          ProgramLevel    @relation(fields: [programLevelId], references: [id], onDelete: Restrict)
  programLevelId String
  placement      PlacementStatus @default(REGULAR) // Regular / Probatorio / Posible graduado
  note           String? // Nota breve del maestro
  gradedAt       DateTime        @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, programId, cycleId])
  @@index([programId, cycleId])
  @@index([cycleId])
}

enum PlacementStatus {
  REGULAR
  PROBATORIO
  POSIBLE_GRADUADO
}

/// Inscripción de un estudiante a un programa (relación con historial).
/// La calificación es POR PROGRAMA: un nivel que el maestro registra/actualiza
/// para el alumno en ese programa (no es un examen con título/puntaje).
model Enrollment {
  id        String           @id @default(cuid())
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  program   Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId String
  // El ciclo en el que está inscrito. Sin esto un alumno solo podía inscribirse a un
  // programa una vez en su vida, y no podía repetirlo en otro ciclo.
  cycle     Cycle            @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  cycleId   String
  startDate DateTime         @default(now())
  endDate   DateTime?
  status    EnrollmentStatus @default(ACTIVA)
  notes     String?

  // Calificación por programa
  level     String? // Nivel: "Inicial", "En proceso", "Logrado"
  levelNote String? // Nota breve del maestro sobre el nivel
  gradedAt  DateTime? // Última vez que se registró la calificación

  createdAt DateTime @default(now())

  @@unique([studentId, programId, cycleId])
  @@index([programId])
  @@index([cycleId])
}

enum EnrollmentStatus {
  ACTIVA
  PAUSADA
  FINALIZADA
}

/// Evaluación / calificación de un estudiante en un momento dado.
model Evaluation {
  id          String   @id @default(cuid())
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId   String
  program     Program? @relation(fields: [programId], references: [id], onDelete: SetNull)
  programId   String?
  date        DateTime @default(now())
  title       String
  score       Float?   // Calificación numérica (opcional)
  scale       String?  // Escala o rúbrica usada (ej. "1-10", "Logrado / En proceso")
  level       String?  // Nivel cualitativo (ej. "Logrado", "En proceso", "Inicial")
  notes       String?
  evaluator   User?    @relation("EvaluadorEvaluaciones", fields: [evaluatorId], references: [id], onDelete: SetNull)
  evaluatorId String?
  createdAt   DateTime @default(now())

  @@index([studentId])
  @@index([date])
}

/// Forma de la plantilla de evaluación de un programa.
enum EvalFormat {
  BLOQUES // Nivel → Bloque numerado (1.1, 1.2…) → Temas (a, b, c). Ej. Matemáticas, Lectura.
  AREAS // Nivel → Área (Receptivo, Expresivo, Social…) → Ítems. Ej. Lenguaje.
  PLANO // Un solo formato sin niveles, secciones con ítems. Ej. Danza, Terapia Ocupacional.
}

/// Bloque / área / sección de un nivel. Es la PLANTILLA (la editan los coordinadores
/// de programas educativos, no la maestra). Para formatos BLOQUES el `code` es "1.1";
/// para AREAS es "Receptivo"; para PLANO agrupa una sección del formato.
model EvalBlock {
  id          String       @id @default(cuid())
  level       ProgramLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)
  levelId     String
  code        String? // "1.2", "Receptivo"… (opcional)
  name        String // Nombre del bloque/área (ej. "Sentido numérico y conteo hasta 10")
  order       Int // Posición dentro del nivel (1 = primero)
  description String?

  items EvalItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([levelId, order])
  @@index([levelId])
}

/// Tema / objetivo dentro de un bloque (ej. "Puedo contar hasta 10"). Parte de la plantilla.
model EvalItem {
  id      String    @id @default(cuid())
  block   EvalBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  blockId String
  code    String? // "a", "b"… (opcional)
  text    String // Redacción del objetivo ("Puedo contar hasta 10")
  order   Int // Posición dentro del bloque

  scores ItemScore[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([blockId, order])
  @@index([blockId])
}

/// Plantilla base reutilizable: la estructura de una evaluación (niveles → bloques →
/// temas) guardada aparte de cualquier programa, para partir de ella al crear uno.
///
/// La estructura va en Json y no en tablas espejo porque es un molde, no datos: nadie
/// califica contra una plantilla base ni la referencia por id. Replicar ProgramLevel /
/// EvalBlock / EvalItem solo para esto duplicaría tres modelos sin ganar nada.
model TemplatePreset {
  id          String     @id @default(cuid())
  name        String // Cómo se llama la plantilla (ej. "Formato plano de terapia")
  description String?
  evalFormat  EvalFormat @default(BLOQUES)

  /// Niveles → bloques → temas. Forma:
  /// [{ name, description?, blocks: [{ name, items: [texto] }] }]
  structure Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Calificación de un alumno en un tema, por ciclo. Escala 1–4 (4 = máximo, dominado).
/// Es la capa de DATOS del alumno; los porcentajes por bloque y nivel se calculan de aquí.
model ItemScore {
  id        String   @id @default(cuid())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  item      EvalItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId    String
  cycle     Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  cycleId   String
  score     Int // 1–4 (respeta la regla: la calificación máxima es 4)
  note      String? // Nota breve del maestro sobre este tema

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, itemId, cycleId])
  @@index([itemId, cycleId])
  @@index([cycleId])
}

/// Horario estructurado de un programa: en qué día y de qué hora a qué hora hay
/// clase. Un programa puede tener varios (ej. lunes y miércoles). Es lo que pinta
/// el calendario; el campo de texto `schedule` queda como descripción libre.
model ScheduleSlot {
  id        String  @id @default(cuid())
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId String
  weekday   Int // Día de la semana como Date.getDay(): 0=domingo … 6=sábado
  startTime String // "HH:MM" en 24h (ej. "10:00")
  endTime   String // "HH:MM" en 24h (ej. "11:00")

  createdAt DateTime @default(now())

  @@index([programId])
}

/// Una clase concreta de un programa en una fecha: el "panel de control" del día.
/// Nace cuando la maestra pasa lista o escribe la bitácora; guarda las anotaciones
/// de esa sesión y cuelga de ella la asistencia.
model ClassSession {
  id        String   @id @default(cuid())
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId String
  date      DateTime @db.Date // Día de la clase (sin hora)
  notes     String? // Bitácora de la clase (qué se trabajó, acuerdos, pendientes)

  attendance AttendanceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([programId, date])
  @@index([date])
}

/// Asistencia de un alumno en una clase concreta.
model AttendanceRecord {
  id        String           @id @default(cuid())
  session   ClassSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  status    AttendanceStatus
  note      String? // Detalle breve (ej. "llegó 20 min tarde", "aviso de la mamá")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sessionId, studentId])
  @@index([studentId])
}

enum AttendanceStatus {
  PRESENTE
  AUSENTE
  JUSTIFICADO
  RETARDO
}

/// Anotación del equipo sobre un participante. Si `visibleToFamily` está activa,
/// la familia la ve en Mi espacio: es el canal para que los padres estén enterados
/// (avances, avisos, recordatorios). Si no, es una nota interna del equipo.
model StudentNote {
  id        String   @id @default(cuid())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  program   Program? @relation(fields: [programId], references: [id], onDelete: SetNull)
  programId String?
  author    User?    @relation("AutorAnotaciones", fields: [authorId], references: [id], onDelete: SetNull)
  authorId  String?
  body      String
  visibleToFamily Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, visibleToFamily])
  @@index([programId])
}
