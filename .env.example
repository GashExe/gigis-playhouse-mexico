# Variables de entorno de la plataforma Gigi's Playhouse México.
# Copia este archivo como `.env` y rellena los valores reales (NO subir `.env` a GitHub).

# --- Base de datos ---
# Local (desarrollo) usa SQLite:
#   DATABASE_URL="file:./dev.db"
#
# Producción (Supabase / Postgres):
#   DATABASE_URL  -> cadena "Transaction pooler" (puerto 6543) + ?pgbouncer=true  (uso en runtime)
#   DIRECT_URL    -> cadena "Direct connection" (puerto 5432)                     (uso en migraciones)
DATABASE_URL="file:./dev.db"
# DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# --- Sesiones ---
# Clave para firmar los JWT de sesión. Genera una nueva con:  openssl rand -base64 32
SESSION_SECRET="cambia-esto-por-una-clave-segura"
